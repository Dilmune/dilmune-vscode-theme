{
  "name": "dilmune-theme",
  "displayName": "Dilmune Theme",
  "description": "Warm, bold color themes built on terracotta, sage, and verdigris. Eye-comfortable in any light — from cream parchment to candlelit dusk to blue-black night.",
  "version": "1.1.1",
  "publisher": "dilmune",
  "license": "MIT",
  "icon": "icon.png",
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#43392a",
    "theme": "dark"
  },
  "homepage": "https://github.com/Dilmune/dilmune-vscode-theme",
  "bugs": {
    "url": "https://github.com/Dilmune/dilmune-vscode-theme/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dilmune/dilmune-vscode-theme"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "dark",
    "light",
    "warm",
    "warm-dark",
    "terracotta",
    "earthy",
    "cozy",
    "dilmune",
    "gruvbox-alternative",
    "solarized-alternative",
    "catppuccin-alternative",
    "eye-comfort",
    "low-blue-light",
    "parchment",
    "cream",
    "sepia",
    "earth-tones",
    "nature",
    "contrast",
    "brown",
    "night"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "contributes": {
    "markdown.previewStyles": [
      "./markdown-preview.css"
    ],
    "themes": [
      {
        "label": "Dilmune Light",
        "uiTheme": "vs",
        "path": "./themes/dilmune-light.json"
      },
      {
        "label": "Dilmune Light High Contrast",
        "uiTheme": "hc-light",
        "path": "./themes/dilmune-light-high-contrast.json"
      },
      {
        "label": "Dilmune Dim",
        "uiTheme": "vs",
        "path": "./themes/dilmune-dim.json"
      },
      {
        "label": "Dilmune Dusk",
        "uiTheme": "vs-dark",
        "path": "./themes/dilmune-dusk.json"
      },
      {
        "label": "Dilmune Dusk High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/dilmune-dusk-high-contrast.json"
      },
      {
        "label": "Dilmune Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/dilmune-dark.json"
      },
      {
        "label": "Dilmune Dark High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/dilmune-dark-high-contrast.json"
      }
    ]
  },
  "scripts": {
    "build": "tsx scripts/build.ts",
    "dev": "tsx watch scripts/build.ts",
    "package": "npm run build && vsce package",
    "publish": "npm run build && vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vscode/vsce": "^3.0.0",
    "culori": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
