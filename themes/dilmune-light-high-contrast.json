  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c50000"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#c50000"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#8c3c00"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#005f52"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#b30100"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#1f2228"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#b40a00"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6d7279",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#4a4d54"
      }
    },
    {
      "name": "HTML/JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#b60000"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8f3f00"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#005f52"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#b40a00"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#b40a00"
      }
    },
    {
      "name": "Regex and escape chars",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#b30042"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#89410d"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.import"
      ],
      "settings": {
        "foreground": "#005c2b"
      }
    },
    {
      "name": "Go functions",
      "scope": [
        "source.go entity.name.function"
      ],
      "settings": {
        "foreground": "#005f52"
      }
    },
    {
      "name": "Go types",
      "scope": [
        "source.go storage.type"
      ],
      "settings": {
        "foreground": "#b30100"
      }
    },
    {
      "name": "TSX component tags",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#b60000"
      }
    },
    {
      "name": "TSX embedded expressions",
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#4a4d54"
      }
    },
    {
      "name": "TypeScript types",
      "scope": [
        "entity.name.type.tsx",
        "entity.name.type.ts"
      ],
      "settings": {
        "foreground": "#b30100"
      }
    },
    {
      "name": "Python builtins",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#005f52"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#89410d"
      }
    },
    {
      "name": "Rust storage",
      "scope": [
        "storage.type.rust"
      ],
      "settings": {
        "foreground": "#c50000"
      }
    },
    {
      "name": "SQL DML keywords",
      "scope": [
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql"
      ],
      "settings": {
        "foreground": "#c50000"
      }
    },
    {
      "name": "SQL table names",
      "scope": [
        "constant.other.table-name.sql"
      ],
      "settings": {
        "foreground": "#b30100"
      }
    },
    {
      "name": "SQL database names",
      "scope": [
        "constant.other.database-name.sql"
      ],
      "settings": {
        "foreground": "#005c2b"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8f3f00"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#8f3f00"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#c50000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#8c3c00"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#005f52"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#005f52",
    "function.declaration": "#006052",
    "method": "#005f52",
    "variable": "#1f2228",
    "variable.readonly": "#b40a00",
    "parameter": "#181b21",
    "property": "#1f2228",
    "type": "#b30100",
    "class": "#b30100",
    "interface": "#ac1f15",
    "enum": "#b30100",
    "enumMember": "#b40a00",
    "namespace": "#005c2b",
    "decorator": "#89410d",
    "comment": {
      "foreground": "#6d7279",
      "fontStyle": "italic"
    },
    "string": "#8c3c00",
    "number": "#b40a00",
    "keyword": "#c50000",
    "operator": "#4a4d54"
  }
}
