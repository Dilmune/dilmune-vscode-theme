  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#92bb89"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.definition.interpolation.begin",
        "punctuation.definition.interpolation.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end",
        "constant.character.format.placeholder",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "support.type.builtin.go"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.builtin.go",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#70b4a6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#c9c3bf"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a736f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation",
        "comment.block.documentation.phpdoc",
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#8c847f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#96918d"
      }
    },
    {
      "name": "HTML tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "JSX/TSX component tags",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c3a677"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "CSS custom properties",
      "scope": [
        "variable.css",
        "variable.other.custom-property.css",
        "support.type.custom-property.css"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "Regex and escape chars",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#c789a6"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#ab8a78"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "keyword.control.directive.include",
        "keyword.control.directive.define",
        "punctuation.definition.directive"
      ],
      "settings": {
        "foreground": "#c789a6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "entity.name.function.macro.rust",
        "support.macro.rust"
      ],
      "settings": {
        "foreground": "#dc7c71",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust/C++ attributes",
      "scope": [
        "meta.attribute.rust",
        "meta.attribute.cpp"
      ],
      "settings": {
        "foreground": "#ab8a78",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.import"
      ],
      "settings": {
        "foreground": "#789d7f"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#c3a677"
      }
    },
    {
      "name": "Support classes (console, Error, Promise)",
      "scope": [
        "support.class.console",
        "support.class.error",
        "support.class.promise"
      ],
      "settings": {
        "foreground": "#d8a07a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go functions",
      "scope": [
        "source.go entity.name.function"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "Go types",
      "scope": [
        "source.go storage.type"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "TypeScript types",
      "scope": [
        "entity.name.type.tsx",
        "entity.name.type.ts"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "Python builtins",
      "scope": [
        "support.function.builtin.python"
