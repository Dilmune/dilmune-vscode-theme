  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#c2ac6f"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#c9c3bf"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#857f7b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#97918d"
      }
    },
    {
      "name": "HTML/JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#dc7f73"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#c3a677"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#d2a066"
      }
    },
    {
      "name": "Regex and escape chars",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#c789a6"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#ab8a78"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.import"
      ],
      "settings": {
        "foreground": "#789d7f"
      }
    },
    {
      "name": "Go functions",
      "scope": [
        "source.go entity.name.function"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "Go types",
      "scope": [
        "source.go storage.type"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "TSX component tags",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#dc7f73"
      }
    },
    {
      "name": "TypeScript types",
      "scope": [
        "entity.name.type.tsx",
        "entity.name.type.ts"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "Python builtins",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#ab8a78"
      }
    },
    {
      "name": "Rust storage",
      "scope": [
        "storage.type.rust"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "SQL DML keywords",
      "scope": [
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql"
      ],
      "settings": {
        "foreground": "#dc7c71"
      }
    },
    {
      "name": "SQL table names",
      "scope": [
        "constant.other.table-name.sql"
      ],
      "settings": {
        "foreground": "#d8a07a"
      }
    },
    {
      "name": "SQL database names",
      "scope": [
        "constant.other.database-name.sql"
      ],
      "settings": {
        "foreground": "#789d7f"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#c3a677"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#c3a677"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#dc7c71",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#c2ac6f"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#70b4a6"
      }
    },
    {
      "name": "This/self/super",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#dc7c71",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Type parameters",
      "scope": [
        "entity.name.type.parameter",
        "meta.type.parameters"
      ],
      "settings": {
        "foreground": "#d8a07a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import/export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#dc7c71",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Interface declarations",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#d8a07a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#70b4a6",
    "function.declaration": "#6db5a6",
    "method": "#70b4a6",
    "variable": "#c9c3bf",
    "variable.readonly": "#d2a066",
    "parameter": "#bfb9b5",
    "property": "#c9c3bf",
    "type": "#d8a07a",
    "class": "#d8a07a",
    "interface": "#d4a280",
    "enum": "#d8a07a",
    "enumMember": "#d2a066",
    "namespace": "#789d7f",
    "decorator": "#ab8a78",
    "comment": {
      "foreground": "#857f7b",
      "fontStyle": "italic"
    },
    "string": "#c2ac6f",
    "number": "#d2a066",
    "keyword": "#dc7c71",
    "operator": "#97918d",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    },
    "variable.defaultLibrary": {
      "foreground": "#dc7c71",
      "fontStyle": "italic"
    },
    "selfKeyword": {
      "foreground": "#dc7c71",
      "fontStyle": "italic"
    }
  }
}
