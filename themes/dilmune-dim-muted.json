  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#953f35"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#953f35"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#2d5228"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.definition.interpolation.begin",
        "punctuation.definition.interpolation.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end",
        "constant.character.format.placeholder",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#953f35"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#2d5347"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#754f32"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "support.type.builtin.go"
      ],
      "settings": {
        "foreground": "#754f32"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.builtin.go",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#2d5347",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#1d1f22"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#75472f"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6d6864",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation",
        "comment.block.documentation.phpdoc",
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#635c58",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#676360"
      }
    },
    {
      "name": "HTML tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#953f35"
      }
    },
    {
      "name": "JSX/TSX component tags",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#754f32"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6b4c2f"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#2d5347"
      }
    },
    {
      "name": "CSS custom properties",
      "scope": [
        "variable.css",
        "variable.other.custom-property.css",
        "support.type.custom-property.css"
      ],
      "settings": {
        "foreground": "#75472f"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#75472f"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#75472f"
      }
    },
    {
      "name": "Regex and escape chars",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#7b445f"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#6d4834"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "keyword.control.directive.include",
        "keyword.control.directive.define",
        "punctuation.definition.directive"
      ],
      "settings": {
        "foreground": "#7b445f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "entity.name.function.macro.rust",
        "support.macro.rust"
      ],
      "settings": {
        "foreground": "#953f35",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust/C++ attributes",
      "scope": [
        "meta.attribute.rust",
        "meta.attribute.cpp"
      ],
      "settings": {
        "foreground": "#6d4834",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.import"
      ],
      "settings": {
        "foreground": "#2a4f36"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#6b4c2f"
      }
    },
    {
      "name": "Support classes (console, Error, Promise)",
      "scope": [
        "support.class.console",
        "support.class.error",
        "support.class.promise"
      ],
      "settings": {
        "foreground": "#754f32",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go functions",
      "scope": [
        "source.go entity.name.function"
      ],
      "settings": {
        "foreground": "#2d5347"
      }
    },
    {
      "name": "Go types",
      "scope": [
        "source.go storage.type"
      ],
      "settings": {
        "foreground": "#754f32"
      }
    },
    {
      "name": "TypeScript types",
      "scope": [
        "entity.name.type.tsx",
        "entity.name.type.ts"
      ],
      "settings": {
        "foreground": "#754f32"
      }
    },
    {
      "name": "Python builtins",
      "scope": [
