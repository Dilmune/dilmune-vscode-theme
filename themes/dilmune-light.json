  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b62000"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#b62000"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#904a00"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#006056"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#ab3415"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#1f2227"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#b23f00"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6e7278",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#52555b"
      }
    },
    {
      "name": "HTML/JSX tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#a82700"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8a4e00"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#006056"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#b23f00"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#b23f00"
      }
    },
    {
      "name": "Regex and escape chars",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#aa2e4e"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#824f32"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.import"
      ],
      "settings": {
        "foreground": "#005d39"
      }
    },
    {
      "name": "Go functions",
      "scope": [
        "source.go entity.name.function"
      ],
      "settings": {
        "foreground": "#006056"
      }
    },
    {
      "name": "Go types",
      "scope": [
        "source.go storage.type"
      ],
      "settings": {
        "foreground": "#ab3415"
      }
    },
    {
      "name": "TSX component tags",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#a82700"
      }
    },
    {
      "name": "TSX embedded expressions",
      "scope": [
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#52555b"
      }
    },
    {
      "name": "TypeScript types",
      "scope": [
        "entity.name.type.tsx",
        "entity.name.type.ts"
      ],
      "settings": {
        "foreground": "#ab3415"
      }
    },
    {
      "name": "Python builtins",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#006056"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#824f32"
      }
    },
    {
      "name": "Rust storage",
      "scope": [
        "storage.type.rust"
      ],
      "settings": {
        "foreground": "#b62000"
      }
    },
    {
      "name": "SQL DML keywords",
      "scope": [
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql"
      ],
      "settings": {
        "foreground": "#b62000"
      }
    },
    {
      "name": "SQL table names",
      "scope": [
        "constant.other.table-name.sql"
      ],
      "settings": {
        "foreground": "#ab3415"
      }
    },
    {
      "name": "SQL database names",
      "scope": [
        "constant.other.database-name.sql"
      ],
      "settings": {
        "foreground": "#005d39"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8a4e00"
      }
    },
    {
      "name": "YAML keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#8a4e00"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#b62000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#904a00"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#006056"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#006056",
    "function.declaration": "#006156",
    "method": "#006056",
    "variable": "#1f2227",
    "variable.readonly": "#b23f00",
    "parameter": "#181b20",
    "property": "#1f2227",
    "type": "#ab3415",
    "class": "#ab3415",
    "interface": "#a53c22",
    "enum": "#ab3415",
    "enumMember": "#b23f00",
    "namespace": "#005d39",
    "decorator": "#824f32",
    "comment": {
      "foreground": "#6e7278",
      "fontStyle": "italic"
    },
    "string": "#904a00",
    "number": "#b23f00",
    "keyword": "#b62000",
    "operator": "#52555b"
  }
}
