  "tokenColors": [
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9e0000"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#9e0000"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#025200"
      }
    },
    {
      "name": "String interpolation",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.definition.interpolation.begin",
        "punctuation.definition.interpolation.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end",
        "constant.character.format.placeholder",
        "meta.template.expression"
      ],
      "settings": {
        "foreground": "#9e0000"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#005240"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#832f00"
      }
    },
    {
      "name": "Built-in types",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "support.type.builtin.go"
      ],
      "settings": {
        "foreground": "#832f00"
      }
    },
    {
      "name": "Built-in functions",
      "scope": [
        "support.function.builtin",
        "support.function.builtin.go",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#005240",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other"
      ],
      "settings": {
        "foreground": "#181b1f"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#7a2e00"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#736a64",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation",
        "comment.block.documentation.phpdoc",
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#60564f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.type",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#4e4640"
      }
    },
    {
      "name": "HTML tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#9e0000"
      }
    },
    {
      "name": "JSX/TSX component tags",
      "scope": [
        "support.class.component.tsx",
        "support.class.component.jsx"
      ],
      "settings": {
        "foreground": "#832f00"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#683d00"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#004f3f"
      }
    },
    {
      "name": "CSS custom properties",
      "scope": [
        "variable.css",
        "variable.other.custom-property.css",
        "support.type.custom-property.css"
      ],
      "settings": {
        "foreground": "#7a2e00"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#7a2e00"
      }
    },
    {
      "name": "CSS units",
      "scope": [
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#7a2e00"
      }
    },
    {
      "name": "Regex and escape chars",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#812258"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#6f3f22"
      }
    },
    {
      "name": "Preprocessor",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "keyword.control.directive.include",
        "keyword.control.directive.define",
        "punctuation.definition.directive"
      ],
      "settings": {
        "foreground": "#812258",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust macros",
      "scope": [
        "entity.name.function.macro.rust",
        "support.macro.rust"
      ],
      "settings": {
        "foreground": "#9e0000",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Rust/C++ attributes",
      "scope": [
        "meta.attribute.rust",
        "meta.attribute.cpp"
      ],
      "settings": {
        "foreground": "#6f3f22",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.import"
      ],
      "settings": {
        "foreground": "#004c2a"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#683d00"
      }
    },
    {
      "name": "Support classes (console, Error, Promise)",
      "scope": [
        "support.class.console",
        "support.class.error",
        "support.class.promise"
      ],
      "settings": {
        "foreground": "#832f00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Go functions",
      "scope": [
        "source.go entity.name.function"
      ],
      "settings": {
        "foreground": "#005240"
      }
    },
    {
      "name": "Go types",
      "scope": [
        "source.go storage.type"
      ],
      "settings": {
        "foreground": "#832f00"
      }
    },
    {
      "name": "TypeScript types",
      "scope": [
        "entity.name.type.tsx",
        "entity.name.type.ts"
      ],
      "settings": {
        "foreground": "#832f00"
      }
    },
    {
      "name": "Python builtins",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#005240",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Rust lifetimes",
      "scope": [
        "entity.name.lifetime.rust"
      ],
      "settings": {
        "foreground": "#6f3f22"
      }
    },
    {
      "name": "Rust storage",
      "scope": [
        "storage.type.rust"
      ],
      "settings": {
        "foreground": "#9e0000"
      }
    },
    {
      "name": "SQL DML keywords",
      "scope": [
        "keyword.other.DML.sql",
